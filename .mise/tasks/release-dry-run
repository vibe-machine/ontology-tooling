#!/usr/bin/env bash
#MISE description="Preview the next ontology release without mutating git state"
#USAGE arg "<repo>" help="Path to the ontology repository to preview"
#USAGE arg "[bump]" help="Semver bump kind" default="patch" {
#USAGE   choices "patch" "minor" "major"
#USAGE }
set -euo pipefail

exec node src/cli/ontology-release.mjs --repo "${usage_repo?}" --bump "${usage_bump?}" --dry-run
